---
const navLinks = [
  { href: '/', label: 'Inlägg' },
  { href: '/om', label: 'Om' },
  { href: '/rss.xml', label: 'RSS' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-200 bg-white/90 backdrop-blur-sm sticky top-0 z-40">
  <div class="app-layout">
    <div class="flex items-center justify-between h-14">
      <a
        href="/"
        class="font-bold text-base tracking-tight text-slate-900 hover:text-slate-700 no-underline"
        aria-label="Shift+Build — hem"
      >
        Shift<span class="text-indigo-600">+</span>Build
      </a>

      <nav class="flex items-center gap-0.5" aria-label="Huvudnavigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
            class="text-sm text-slate-500 hover:text-slate-900 px-3 py-1.5 rounded transition-colors aria-[current=page]:text-slate-900"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

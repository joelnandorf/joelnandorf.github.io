---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: base || '/', label: 'Inlägg' },
  { href: `${base}/amnen`, label: 'Ämnen' },
  { href: `${base}/om`, label: 'Om' },
  { href: `${base}/rss.xml`, label: 'RSS' },
];

const homeHref = base || '/';
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 bg-background/95 backdrop-blur-sm border-b border-outline-variant/40"
>
  <div class="app-layout flex items-center justify-between h-16 md:h-20">
    <a
      href={base || '/'}
      class="font-display text-xl md:text-2xl text-ink tracking-tight no-underline hover:text-accent transition-colors"
      aria-label="Shift+Build — hem"
    >
      Shift<span class="text-accent">+</span>Build
    </a>

    <nav
      class="flex items-center gap-6 md:gap-8 text-sm"
      aria-label="Huvudnavigation"
    >
      {
        navLinks.map((link) => {
          const isActive =
            currentPath === link.href ||
            (link.href !== homeHref && currentPath.startsWith(`${link.href}/`));
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class={`pb-1 border-b no-underline transition-colors duration-300 ${
                isActive
                  ? 'text-ink border-ink'
                  : 'text-ink-muted border-transparent hover:text-ink hover:border-outline-variant'
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>

---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-auto border-t border-outline-variant/40 bg-surface-container-low">
  <div class="app-layout py-12 md:py-16 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
    <div class="text-center md:text-left">
      <span class="font-display text-xl text-ink block mb-2">Shift+Build</span>
      <p class="text-sm text-ink-muted leading-relaxed max-w-[36ch] mx-auto md:mx-0">
        Perspektiv inifrån skiftet — av Joel Nandorf.
      </p>
    </div>

    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm" aria-label="Footer-navigation">
      <a
        href={`${base}/rss.xml`}
        class="text-ink-muted hover:text-ink underline decoration-accent decoration-1 underline-offset-4 transition-colors duration-200"
      >RSS</a>
      <a
        href="https://www.linkedin.com/in/joelnandorf"
        rel="noopener noreferrer"
        target="_blank"
        class="text-ink-muted hover:text-ink underline decoration-accent decoration-1 underline-offset-4 transition-colors duration-200"
      >LinkedIn</a>
      <a
        href="https://substack.com/@joelnandorf"
        rel="noopener noreferrer"
        target="_blank"
        class="text-ink-muted hover:text-ink underline decoration-accent decoration-1 underline-offset-4 transition-colors duration-200"
      >Substack</a>
    </nav>
  </div>

  <div class="app-layout pb-8 text-center md:text-left">
    <p class="text-xs text-ink-muted">
      Byggd med <a href="https://astro.build" rel="noopener noreferrer" target="_blank" class="hover:text-ink transition-colors">Astro</a>.
      Öppen källkod på <a href="https://github.com/joelnandorf/shiftandbuild" rel="noopener noreferrer" target="_blank" class="hover:text-ink transition-colors">GitHub</a>.
    </p>
  </div>
</footer>

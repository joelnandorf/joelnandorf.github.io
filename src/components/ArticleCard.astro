---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getTopicLabel } from '../lib/topics';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
  topic: string;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
}

const { title, description, pubDate, slug, topic, heroImage, heroImageAlt } =
  Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const dateOptions: Intl.DateTimeFormatOptions = {
  day: 'numeric',
  month: 'short',
};
---

<article
  class="group relative flex flex-col md:flex-row gap-6 md:gap-10 items-start"
>
  {
    heroImage && (
      <div class="w-full md:w-2/5 shrink-0 aspect-[3/2] overflow-hidden rounded bg-surface-container-high">
        <Image
          src={heroImage}
          alt={heroImageAlt ?? ''}
          width={480}
          height={320}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>
    )
  }

  <div class="flex flex-col justify-center py-1 min-w-0">
    <span
      class="font-sans text-xs font-semibold tracking-[0.15em] uppercase text-ink-muted mb-3"
    >
      <a
        href={`${base}/amnen/${topic}`}
        class="relative z-10 no-underline text-inherit hover:text-accent transition-colors"
      >
        {getTopicLabel(topic)}
      </a>
      {' '}· {pubDate.toLocaleDateString('sv-SE', dateOptions)}
    </span>

    <h2
      class="font-display text-2xl md:text-3xl text-ink leading-snug mb-3 group-hover:text-accent transition-colors duration-300"
    >
      <a
        href={`${base}/blog/${slug}`}
        class="no-underline text-inherit after:absolute after:inset-0"
      >
        {title}
      </a>
    </h2>

    <p class="text-ink-muted leading-relaxed">
      {description}
    </p>
  </div>
</article>

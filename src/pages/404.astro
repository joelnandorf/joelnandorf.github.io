---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Shift+Build"
  description="Sidan hittades inte."
>
  <section class="app-layout py-20">
    <h1 class="font-semibold text-2xl tracking-tight mb-4">
      404 — den här sidan är inte byggd ännu
    </h1>
    <p class="text-slate-500 leading-relaxed max-w-[46ch] mb-6">
      Sidan du letar efter finns inte. Kanske ett gammalt länk, kanske en felstavning.
      Gå tillbaka till startsidan så hittar du det senaste.
    </p>
    <a
      href="/"
      class="text-sm text-indigo-600 hover:underline"
    >
      ← Till startsidan
    </a>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="404 — Shift+Build"
  description="Sidan hittades inte."
>
  <section class="reading-column py-24 md:py-32 text-center">
    <span class="font-display text-6xl text-accent block mb-6">404</span>
    <h1 class="font-display text-2xl md:text-3xl text-ink tracking-tight mb-4">
      Den här sidan är inte byggd ännu
    </h1>
    <p class="text-ink-muted leading-relaxed max-w-[46ch] mx-auto mb-8">
      Sidan du letar efter finns inte. Kanske ett gammalt länk, kanske en felstavning.
      Gå tillbaka till startsidan så hittar du det senaste.
    </p>
    <a
      href={base || '/'}
      class="text-sm text-accent underline decoration-accent underline-offset-4"
    >
      ← Till startsidan
    </a>
  </section>
</BaseLayout>

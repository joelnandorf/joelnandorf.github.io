---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Shift+Build — bygga på gränsen mellan kod, produkt och design"
  description="Perspektiv från en tech lead i en produkttrio: AI-arkitektur i praktiken, tekniskt ledarskap utan mandat, och hur rollerna inom produktutveckling konvergerar."
>
  <section class="app-layout pt-16 pb-14 md:pt-24 md:pb-20 text-center border-b border-outline-variant/40">
    <h1 class="font-display text-4xl md:text-6xl text-ink leading-[1.1] tracking-tight mb-6 max-w-[20ch] mx-auto">
      Perspektiv från någon som bygger på gränsen mellan kod, produkt och design.
    </h1>
    <div class="max-w-[56ch] mx-auto space-y-4">
      <p class="text-ink-muted text-lg leading-relaxed">
        Jag är tech lead, sitter i en produkttrio och jobbar med AI i produktion. Här skriver
        jag om vad jag faktiskt ser förändras — AI-arkitektur i praktiken, tekniskt ledarskap
        utan mandat, och hur gränsen mellan att koda, designa och äga en produkt blir tunnare
        för varje år.
      </p>
      <p class="text-ink-muted text-lg leading-relaxed">
        Inget om hur saker borde fungera i teorin. Bara hur de fungerar när man sitter mitt i det.
      </p>
    </div>
  </section>

  <section class="reading-column py-16 md:py-20">
    <h2 class="font-sans text-xs font-semibold tracking-[0.2em] uppercase text-ink-muted mb-10 text-center">
      Senaste inläggen
    </h2>

    {posts.length === 0 ? (
      <p class="text-ink-muted text-center py-8">
        Första inläggen är på väg. Kom tillbaka snart, eller följ via{' '}
        <a href={`${base}/rss.xml`} class="text-accent underline decoration-accent underline-offset-4">RSS</a> så missar du inget.
      </p>
    ) : (
      <div class="flex flex-col gap-14 md:gap-16">
        {posts.map((post, index) => (
          <Fragment>
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id.replace(/\.md$/, '')}
              tags={post.data.tags}
              pillar={post.data.pillar}
              heroImage={post.data.heroImage}
              heroImageAlt={post.data.heroImageAlt}
            />
            {index < posts.length - 1 && (
              <hr class="border-t-[0.5px] border-outline-variant w-16 mx-auto" />
            )}
          </Fragment>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
